pipeline {

    agent any 

    environment {

        NPM_TOKEN = credentials('NPM_TOKEN')

    }

    stages {

        stage('Build') {
            steps {
                sh 'node --version'
                sh 'npm install'
            }
        }

        stage('Test') {
            steps {
                sh 'npm test'
            }
        }


        stage('Publish') {
            steps {
                
                sh 'npm publish'
            }
        }
    }


}